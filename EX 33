import cv2
import numpy as np
def create_rectangle_image(width, height):
    image = np.ones((height, width, 3), dtype=np.uint8) * 255
    start_point = (width // 4, height // 4)
    end_point = (3 * width // 4, 3 * height // 4)
    color = (0, 0, 255)
    thickness = 3
    cv2.rectangle(image, start_point, end_point, color, thickness)
    cv2.imshow("Rectangle Image", image)
    cv2.waitKey(0)
    cv2.destroyAllWindows()
    cv2.imwrite("rectangle_image.jpg", image)
width = int(input("Enter width of the image: "))
height = int(input("Enter height of the image: "))
create_rectangle_image(width, height)
