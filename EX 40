import cv2
import pytesseract
def extract_text_from_video(video_path):
    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        print(f"Error opening video {video_path}")
        return
    frame_count = 0
    while True:
        ret, frame = cap.read()
        if not ret:
            break
        frame_count += 1
        text = pytesseract.image_to_string(frame)
        if text.strip():
            print(f"Frame {frame_count} Text:\n{text}\n{'-'*30}")
    cap.release()
extract_text_from_video("input_video.mp4")
