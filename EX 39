import cv2
import time
def play_video_reverse_slow(video_path, slow_factor=2):
    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        print(f"Error opening video {video_path}")
        return
    frames = []
    while True:
        ret, frame = cap.read()
        if not ret:
            break
        frames.append(frame)
    cap.release()
    for frame in reversed(frames):
        cv2.imshow("Reverse Slow Motion", frame)
        if cv2.waitKey(int(1000/30*slow_factor)) & 0xFF == ord('q'):
            break
    cv2.destroyAllWindows()
play_video_reverse_slow("input_video.mp4", slow_factor=3)
