import cv2
import numpy as np

def create_circle_image(width, height):
    image = np.ones((height, width, 3), dtype=np.uint8) * 255
    center = (width // 2, height // 2)
    radius = min(width, height) // 4
    color = (0, 0, 255)
    thickness = 3
    cv2.circle(image, center, radius, color, thickness)
    cv2.imshow("Circle Image", image)
    cv2.waitKey(0)
    cv2.destroyAllWindows()
    cv2.imwrite("circle_image.jpg", image)

width = int(input("Enter width of the image: "))
height = int(input("Enter height of the image: "))
create_circle_image(width, height)
